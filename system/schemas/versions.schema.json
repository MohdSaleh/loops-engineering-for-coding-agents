{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Goal Versions Projection v3.0",
  "type": "object",
  "required": [
    "schema_version",
    "projection",
    "sequence_counter",
    "active_goal_id",
    "versions"
  ],
  "properties": {
    "schema_version": {
      "const": "3.0"
    },
    "projection": {
      "type": "object"
    },
    "sequence_counter": {
      "type": "integer"
    },
    "active_goal_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "versions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
