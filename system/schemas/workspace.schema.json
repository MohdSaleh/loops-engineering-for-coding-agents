{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic Workspace v3.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace_id",
    "mode",
    "workspace_root",
    "control_root",
    "instruction_entrypoint",
    "default_project_id",
    "projects",
    "ownership",
    "protected_paths",
    "generated_paths",
    "kg_exclude",
    "system_change_requires_explicit_goal"
  ],
  "properties": {
    "schema_version": {
      "const": "3.0"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "embedded",
        "nested",
        "multi_project"
      ]
    },
    "workspace_root": {
      "type": "string"
    },
    "control_root": {
      "type": "string",
      "minLength": 1
    },
    "instruction_entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "default_project_id": {
      "type": "string",
      "minLength": 1
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "project_id",
          "root",
          "command_cwd",
          "source_roots",
          "test_roots",
          "documentation_roots",
          "asset_roots",
          "config_files",
          "validation_profile",
          "kg_adapters"
        ],
        "properties": {
          "project_id": {
            "type": "string",
            "minLength": 1
          },
          "root": {
            "type": "string"
          },
          "command_cwd": {
            "type": "string"
          },
          "source_roots": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "test_roots": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "documentation_roots": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "asset_roots": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "config_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validation_profile": {
            "type": "string"
          },
          "kg_adapters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "ownership": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pattern",
          "class",
          "write_roles"
        ],
        "properties": {
          "pattern": {
            "type": "string",
            "minLength": 1
          },
          "class": {
            "enum": [
              "CONTROL_PLANE",
              "RUNTIME_STATE",
              "KNOWLEDGE_GENERATED",
              "PROJECT",
              "BUILD_OUTPUT",
              "VENDOR_EXTERNAL",
              "UNCLASSIFIED"
            ]
          },
          "write_roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "protected_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kg_exclude": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "system_change_requires_explicit_goal": {
      "type": "boolean"
    }
  }
}
