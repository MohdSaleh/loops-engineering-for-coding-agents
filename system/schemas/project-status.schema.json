{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project Status Projection v3.0",
  "type": "object",
  "required": [
    "schema_version",
    "project_id",
    "status",
    "requirements",
    "completion"
  ],
  "properties": {
    "schema_version": {
      "const": "3.0"
    },
    "project_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "NOT_STARTED",
        "IN_PROGRESS",
        "BLOCKED",
        "READY_FOR_ACCEPTANCE",
        "COMPLETED"
      ]
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "completion": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
